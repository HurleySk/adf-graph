{
  "name": "Test_Orchestrator",
  "properties": {
    "parameters": {
      "rootbusinessunit": {
        "type": "String",
        "defaultValue": ""
      },
      "dataverse_service_uri": {
        "type": "String",
        "defaultValue": "https://org.crm.dynamics.com"
      }
    },
    "activities": [
      {
        "name": "Run Copy To Staging",
        "type": "ExecutePipeline",
        "dependsOn": [],
        "typeProperties": {
          "pipeline": {
            "referenceName": "Copy_To_Staging",
            "type": "PipelineReference"
          },
          "waitOnCompletion": true,
          "parameters": {
            "source_query": "SELECT org_id, org_name FROM dbo.Work_Item_Milestone WHERE active = 1",
            "source_object_name": "LegacyOrg",
            "dest_object_name": "Org_Staging",
            "dest_schema_name": "dbo",
            "dataverse_entity_name": "alm_organization"
          }
        }
      },
      {
        "name": "Run CDC OnPrem",
        "type": "ExecutePipeline",
        "dependsOn": [],
        "typeProperties": {
          "pipeline": {
            "referenceName": "CDC_OnPrem_Template",
            "type": "PipelineReference"
          },
          "waitOnCompletion": true,
          "parameters": {
            "source_query": {
              "value": "SELECT b.Work_Set_State_id, b.Work_Set_fk FROM dbo.Work_Set_State b JOIN dbo.Work_Set_FERC_Organization c ON b.Work_Set_fk = c.Work_Set_fk",
              "type": "Expression"
            },
            "source_object_name": {
              "value": "Work_Set_State",
              "type": "Expression"
            },
            "source_schema_name": "dbo",
            "dest_object_name": {
              "value": "Agenda_Work_Set_State_Staging",
              "type": "Expression"
            },
            "dest_schema_name": "dbo",
            "dataverse_entity_name": "alm_worksetstate"
          }
        }
      },
      {
        "name": "Run SP Transform",
        "type": "ExecutePipeline",
        "dependsOn": [
          {
            "activity": "Run Copy To Staging",
            "dependencyConditions": ["Succeeded"]
          }
        ],
        "typeProperties": {
          "pipeline": {
            "referenceName": "SP_Transform",
            "type": "PipelineReference"
          },
          "waitOnCompletion": true
        }
      },
      {
        "name": "Run Copy To Dataverse",
        "type": "ExecutePipeline",
        "dependsOn": [
          {
            "activity": "Run SP Transform",
            "dependencyConditions": ["Succeeded"]
          }
        ],
        "typeProperties": {
          "pipeline": {
            "referenceName": "Copy_To_Dataverse",
            "type": "PipelineReference"
          },
          "waitOnCompletion": true,
          "parameters": {
            "dataverse_query": "<fetch><entity name='alm_organization'><attribute name='alm_orgid'/></entity></fetch>"
          }
        }
      }
    ],
    "annotations": []
  }
}
