{
  "name": "adf-graph",
  "version": "1.6.2",
  "description": "MCP server that builds a queryable dependency graph from ADF pipeline artifacts",
  "license": "MIT",
  "author": "HurleySk",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/HurleySk/adf-graph.git"
  },
  "homepage": "https://github.com/HurleySk/adf-graph#readme",
  "keywords": [
    "mcp",
    "azure-data-factory",
    "adf",
    "dependency-graph",
    "data-lineage",
    "impact-analysis"
  ],
  "engines": {
    "node": ">=18"
  },
  "type": "module",
  "bin": {
    "adf-graph": "dist/server.js"
  },
  "main": "dist/server.js",
  "files": [
    "dist",
    "README.md",
    "server.json"
  ],
  "scripts": {
    "prebuild": "rm -rf dist",
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.5.0",
    "vitest": "^3.2.0"
  }
}
