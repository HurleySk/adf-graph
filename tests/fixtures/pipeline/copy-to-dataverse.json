{
  "name": "Copy_To_Dataverse",
  "properties": {
    "parameters": {
      "dataverse_query": {
        "type": "String",
        "defaultValue": ""
      }
    },
    "activities": [
      {
        "name": "Upsert Organizations",
        "type": "Copy",
        "dependsOn": [],
        "typeProperties": {
          "source": {
            "type": "AzureSqlSource",
            "sqlReaderQuery": "SELECT org_id, org_name, org_type_code, dv_org_guid FROM dbo.Org_Staging WHERE is_ready = 1"
          },
          "sink": {
            "type": "CommonDataServiceForAppsSink",
            "writeBehavior": "upsert"
          },
          "translator": {
            "type": "TabularTranslator",
            "mappings": [
              {
                "source": {
                  "name": "org_id"
                },
                "sink": {
                  "name": "alm_orgid"
                }
              },
              {
                "source": {
                  "name": "org_name"
                },
                "sink": {
                  "name": "alm_name"
                }
              },
              {
                "source": {
                  "name": "org_type_code"
                },
                "sink": {
                  "name": "alm_orgtypecode"
                }
              }
            ]
          }
        },
        "inputs": [
          {
            "referenceName": "ds_sql_staging",
            "type": "DatasetReference",
            "parameters": {
              "schema_name": "dbo",
              "table_name": "Org_Staging"
            }
          }
        ],
        "outputs": [
          {
            "referenceName": "ds_dataverse",
            "type": "DatasetReference",
            "parameters": {
              "entity_name": "alm_organization"
            }
          }
        ]
      }
    ],
    "annotations": []
  }
}
