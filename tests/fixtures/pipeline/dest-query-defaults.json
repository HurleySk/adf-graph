            "type": "PipelineReference"
          },
          "waitOnCompletion": true,
          "parameters": {
            "dest_query": {
              "value": "@pipeline().parameters.dest_query",
              "type": "Expression"
            },
            "dataverse_entity_name": {
              "value": "@pipeline().parameters.dataverse_entity_name",
              "type": "Expression"
            }
          }
        }
      }
    ],
    "annotations": []
  }
